# Vector store
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=replace_with_your_qdrant_api_key
QDRANT_COLLECTION=clinical_patient_chunks

# Patient journey LLM
PATIENT_JOURNEY_LLM_PROVIDER=groq
PATIENT_JOURNEY_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# Patient journey persistence
JOURNEY_STORE_PROVIDER=json
# DATABASE_URL=postgresql://clinical_ai:replace_with_database_password@postgres:5432/clinical_ai

# Optional async task queue
TASK_QUEUE_PROVIDER=local
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# Optional local log overrides for tests or non-default runtime paths
# CLINICAL_AI_AUDIT_LOG_PATH=data/audit_logs.jsonl
# CLINICAL_AI_JOURNEY_RUN_LOG_PATH=data/journey_runs.jsonl

# Optional API-key auth. If unset, local development remains open.
CLINICAL_AI_DOCTOR_API_KEY=replace_with_doctor_api_key
CLINICAL_AI_ADMIN_API_KEY=replace_with_admin_api_key
